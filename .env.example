# ──────────────────────────────────────────────────────
# 飞书应用凭证（在飞书开放平台 > 应用管理 > 应用凭证 获取）
# ──────────────────────────────────────────────────────
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OAuth 回调地址（必须与飞书应用中配置的重定向 URI 完全一致）
FEISHU_REDIRECT_URI=https://your-site.netlify.app/.netlify/functions/feishu-callback

# Session 签名密钥（任意随机字符串，建议 32 位以上）
FEISHU_SESSION_SECRET=replace-with-a-long-random-secret-string

# ──────────────────────────────────────────────────────
# 飞书多维表格 — 二选一
# ──────────────────────────────────────────────────────
# 方案 A：直接填写 Bitable app_token（从多维表格 URL 中获取）
FEISHU_BITABLE_APP_TOKEN=

# 方案 B：如果表格在飞书知识库（Wiki）中，填写 Wiki node token
FEISHU_WIKI_NODE_TOKEN=

# ──────────────────────────────────────────────────────
# 各面板对应的飞书多维表格 table_id
# （在多维表格 URL 中 /tables/ 后面的部分）
# ──────────────────────────────────────────────────────
FEISHU_TABLE_A1=tblxxxxxxxxxxxxxxx   # A1 已实现真实写入，必须配置
FEISHU_TABLE_A2=                     # scaffold，配置后可用
FEISHU_TABLE_A3=
FEISHU_TABLE_A4=
FEISHU_TABLE_B2=
FEISHU_TABLE_B3=
FEISHU_TABLE_B4=
FEISHU_TABLE_B5=
FEISHU_TABLE_B6=
